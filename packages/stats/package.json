{
  "name": "@socialgouv/cdtn-stats",
  "version": "4.230.2",
  "private": true,
  "type": "module",
  "description": "Extraction statique et drift-check des events Matomo émis par le frontend CDTN.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SocialGouv/code-du-travail-numerique.git",
    "directory": "packages/stats"
  },
  "scripts": {
    "events:extract": "tsx src/extract-events.ts",
    "events:check": "tsx src/check-events.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"./src/**/*.ts\"",
    "format": "prettier --write \"./src/**/*.ts\"",
    "format:check": "prettier --check \"./src/**/*.ts\"",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "ts-morph": "^27.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "lint-staged": {
    "*.ts": [
      "pnpm lint --fix --quiet",
      "pnpm format"
    ]
  }
}
