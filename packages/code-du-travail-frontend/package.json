{
  "name": "@cdt/frontend",
  "version": "4.236.0",
  "description": "Code du travail frontend",
  "private": true,
  "homepage": "https://code-du-travail.beta.gouv.fr/",
  "keywords": [],
  "main": "src/index.js",
  "scripts": {
    "dev": "react-dsfr update-icons && panda codegenv && next dev",
    "lint": "pnpm codegen && eslint .",
    "precommit": "lint-staged --concurrent 1",
    "start": "next start",
    "tsup": "tsup",
    "codegen": "pnpm tsup && node dist/prebuild-cli.js && react-dsfr update-icons && panda codegen && next typegen",
    "build": "pnpm codegen && next build",
    "build:analyze": "pnpm codegen && ANALYZE=true next build",
    "test": "pnpm codegen && ELASTICSEARCH_URL=http://localhost:9200 NEXT_PUBLIC_ES_INDEX_PREFIX=cdtn_test NEXT_PUBLIC_APP_ENV=test NODE_ENV=test node dist/generate-data.js && ELASTICSEARCH_URL=http://localhost:9200 NEXT_PUBLIC_ES_INDEX_PREFIX=cdtn_test NEXT_PUBLIC_APP_ENV=test NODE_ENV=test jest --silent",
    "test:watch": "pnpm test --watch",
    "test:frontend": "NEXT_PUBLIC_APP_ENV=test NODE_ENV=test jest --silent --testPathIgnorePatterns='.*\\.es\\.test\\.ts$|.*\\.script\\.test\\.ts$'",
    "test:frontend:update": "pnpm test:frontend --updateSnapshot",
    "test:api": "pnpm tsup && ELASTICSEARCH_URL=http://localhost:9200 NEXT_PUBLIC_ES_INDEX_PREFIX=cdtn_test NEXT_PUBLIC_APP_ENV=test NODE_ENV=test node dist/generate-data.js && ELASTICSEARCH_URL=http://localhost:9200 NEXT_PUBLIC_ES_INDEX_PREFIX=cdtn_test NEXT_PUBLIC_APP_ENV=test NODE_ENV=test jest --silent --testPathPatterns='.*\\.es\\.test\\.ts$'",
    "test:api:update": "pnpm test:api --updateSnapshot",
    "test:update": "pnpm test:frontend:update",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "type-check": "pnpm codegen && tsc --noEmit",
    "type-check:watch": "pnpm run type-check -- --watch",
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,jsx,json,md}\"",
    "clean:redirects": "pnpm tsup && node dist/clean-redirects.js"
  },
  "dependencies": {
    "@codegouvfr/react-dsfr": "^1.32.2",
    "@elastic/elasticsearch": "^8.19.1",
    "@matejmazur/react-katex": "^3.1.3",
    "@opentelemetry/instrumentation-generic-pool": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-net": "^0.62.0",
    "@sentry/nextjs": "~10.55.0",
    "@socialgouv/cdtn-elasticsearch": "^2.74.0",
    "@socialgouv/cdtn-types": "^2.74.0",
    "@socialgouv/cdtn-utils": "link:../code-du-travail-utils",
    "@socialgouv/dila-api-client": "1.2.4",
    "@socialgouv/matomo-next": "^1.14.2",
    "@socialgouv/modeles-social": "link:../code-du-travail-modeles",
    "date-fns": "^4.4.0",
    "debounce-promise": "^3.1.2",
    "debug": "^4.4.3",
    "downshift": "^9.3.3",
    "fuse.js": "^7.4.0",
    "fuzzball": "^2.2.6",
    "html-react-parser": "^6.1.2",
    "immer": "^11.1.8",
    "katex": "^0.17.0",
    "lodash.deburr": "^4.1.0",
    "memoizee": "^0.4.17",
    "next": "~16.2.7",
    "node-fetch": "^2.6.6",
    "publicodes": "1.0.0-beta.60",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "sharp": "^0.34.5",
    "simple-oauth2": "^4.2.0",
    "talisman": "^1.1.4",
    "uuid": "^14.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@pandacss/dev": "^1.11.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/debounce-promise": "^3.1.9",
    "@types/jest": "^30.0.0",
    "@types/node": "~25.2.0",
    "@types/react": "~19.2.16",
    "@types/react-dom": "~19.2.3",
    "@types/xml2js": "^0.4.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "~16.2.6",
    "html-validate": "^10.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.2.7",
    "mockdate": "^3.0.5",
    "next-router-mock": "^1.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "testing-library-selector": "0.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "xml2js": "^0.6.2"
  }
}
